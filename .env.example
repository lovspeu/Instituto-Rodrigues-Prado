# =========================================================
# INSTITUTO RODRIGUES PRADO — Exemplo de variáveis de ambiente
# Copie para ".env" e preencha com os valores reais.
# NUNCA comite o arquivo ".env" com valores preenchidos.
# =========================================================

# ---- Servidor ----
PORT=3000
NODE_ENV=development

# ---- Supabase (fonte oficial dos dados) ----
SUPABASE_URL=
SUPABASE_KEY=

# ---- PagBank / PagSeguro ----
PAGBANK_TOKEN=
PAGBANK_ENV=sandbox            # sandbox | production

# ---- Segurança (adicionados na refatoração — Fase 3) ----
# Segredo para assinar o JWT de sessão (gere um valor aleatório forte)
JWT_SECRET=
# Origens permitidas para CORS e Socket.IO, separadas por vírgula
# Ex.: https://seu-app.onrender.com,http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000
